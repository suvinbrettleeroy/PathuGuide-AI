# PathGuide Configuration

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///pathguide.db

# Admin Credentials (CASE-SENSITIVE)
ADMIN_USERNAME=Darkknignt
ADMIN_PASSWORD=Suv001

# Session Configuration
SESSION_TIMEOUT=3600
INACTIVITY_TIMEOUT=1800

# Security
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION=1800

# ML Model Configuration
ML_MODEL_PATH=models/
PREDICTION_THRESHOLD=0.75

# Feature Flags
ENABLE_LOCATION=True
ENABLE_FITNESS_MODULE=True
ENABLE_ML_PREDICTIONS=True
ENABLE_DAILY_STUDY_PLAN=True
ENABLE_MOCK_TESTS=True
ENABLE_NOTIFICATIONS=False
